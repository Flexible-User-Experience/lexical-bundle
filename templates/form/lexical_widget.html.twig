{#
    Form theme for FlexibleUx\Form\Type\LexicalFormType. Renders the toolbar (icons via
    ux_icon) and the editable surface around the real textarea, all bound to the
    `lexical` Stimulus controller. The controller keeps the textarea in sync with the
    editor's HTML; styling ships in assets/styles/lexical.css (loaded by the controller).

    The Stimulus wiring uses StimulusBundle's Twig helpers (`stimulus_controller`,
    `stimulus_target`, `stimulus_action`) rather than hand-written data-* attributes, so
    the Value API key casing and the JSON encoding of array values are handled for us.
#}
{%- block lexical_widget -%}
    {#- Button name → icon + translation key. Grouping is NOT decided here: the toolbar is
        rendered in the exact order given, and a `lexical__sep` divider is drawn wherever
        the caller placed a separator entry, so applications are free to group as they like. -#}
    {%- set lexical_icons = {
        bold: { icon: 'bold', label: 'toolbar.bold' },
        italic: { icon: 'italic', label: 'toolbar.italic' },
        underline: { icon: 'underline', label: 'toolbar.underline' },
        strikethrough: { icon: 'strikethrough', label: 'toolbar.strikethrough' },
        subscript: { icon: 'subscript', label: 'toolbar.subscript' },
        superscript: { icon: 'superscript', label: 'toolbar.superscript' },
        bullet: { icon: 'list', label: 'toolbar.bullet_list' },
        number: { icon: 'list-ordered', label: 'toolbar.numbered_list' },
        indent: { icon: 'indent-increase', label: 'toolbar.indent' },
        outdent: { icon: 'indent-decrease', label: 'toolbar.outdent' },
        link: { icon: 'link', label: 'toolbar.link' },
        unlink: { icon: 'unlink', label: 'toolbar.unlink' },
    } -%}
    {%- set lexical_sep = lexical_separator|default('|') -%}
    <div class="lexical"
         {{ stimulus_controller('lexical', {
             invalidUrlMessage: 'error.invalid_url'|trans({}, 'FlexibleUxLexical'),
             allowedLinkSchemes: lexical_allowed_link_schemes|default([]),
         }) }}
         style="--lexical-min-height: {{ lexical_height|default('200px') }};">
        <div class="lexical__toolbar" role="toolbar" aria-label="{{ 'toolbar.label'|trans({}, 'FlexibleUxLexical') }}">
            {%- for name in lexical_toolbar|default([]) -%}
                {%- if name == lexical_sep -%}
                    <span class="lexical__sep" aria-hidden="true"></span>
                {%- else -%}
                    {%- set def = lexical_icons[name]|default(null) -%}
                    {%- if def is not null -%}
                        {%- set title = def.label|trans({}, 'FlexibleUxLexical') -%}
                        {#- `data-command` stays a plain attribute: the controller reads it both from
                            the event target and while looping over `buttonTargets` in its toolbar
                            refresh, so keeping it independent of the controller identifier is simpler
                            than a Stimulus action parameter. -#}
                        <button type="button" class="lexical__btn" data-command="{{ name }}"
                                title="{{ title }}" aria-label="{{ title }}"
                                {{ stimulus_target('lexical', 'button')|stimulus_action('lexical', 'preventBlur', 'mousedown')|stimulus_action('lexical', 'command', 'click') }}>
                            {{- ux_icon('lexical:' ~ def.icon, { 'class': 'lexical__icon' }) -}}
                        </button>
                    {%- endif -%}
                {%- endif -%}
            {%- endfor -%}
        </div>
        <div class="lexical__editable" contenteditable="true" role="textbox" aria-multiline="true" spellcheck="true"
             {{ stimulus_target('lexical', 'editable')|stimulus_action('lexical', 'markChanged', 'focusout') }}></div>
        {%- set attr = attr|merge(stimulus_target('lexical', 'input').toArray()) -%}
        {{- block('textarea_widget') -}}
        {#- Native <dialog> link modal. Kept self-contained (plain buttons + Enter to
            confirm) so it never nests or submits the surrounding form. -#}
        <dialog class="lexical__dialog"
                aria-label="{{ 'dialog.link.title'|trans({}, 'FlexibleUxLexical') }}"
                {{ stimulus_target('lexical', 'dialog')|stimulus_action('lexical', 'dialogClosed', 'close') }}>
            <div class="lexical__dialog-body">
                <label class="lexical__dialog-label">
                    {{ 'dialog.link.url_label'|trans({}, 'FlexibleUxLexical') }}
                    <input type="url" class="lexical__dialog-input" placeholder="https://" autofocus
                           {{ stimulus_target('lexical', 'urlInput')|stimulus_action('lexical', 'dialogKeydown', 'keydown') }}>
                </label>
                <label class="lexical__dialog-check">
                    <input type="checkbox" {{ stimulus_target('lexical', 'newTab') }}>
                    {{ 'dialog.link.new_tab'|trans({}, 'FlexibleUxLexical') }}
                </label>
                <div class="lexical__dialog-actions">
                    <button type="button" class="lexical__dialog-btn"
                            {{ stimulus_action('lexical', 'closeDialog') }}>{{ 'dialog.cancel'|trans({}, 'FlexibleUxLexical') }}</button>
                    <button type="button" class="lexical__dialog-btn lexical__dialog-btn--primary"
                            {{ stimulus_action('lexical', 'confirmLink') }}>{{ 'dialog.confirm'|trans({}, 'FlexibleUxLexical') }}</button>
                </div>
            </div>
        </dialog>
    </div>
{%- endblock -%}
