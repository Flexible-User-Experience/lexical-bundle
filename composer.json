{
    "name": "flexible-ux/lexical-bundle",
    "type": "symfony-bundle",
    "description": "A reusable Symfony form type providing a lightweight Lexical (Meta) rich-text editor, wired with AssetMapper, Stimulus and UX Icons.",
    "keywords": [
        "symfony",
        "symfony-bundle",
        "symfony-ux",
        "lexical",
        "wysiwyg",
        "rich-text",
        "editor",
        "form",
        "stimulus",
        "asset-mapper"
    ],
    "homepage": "https://github.com/flexible-ux/lexical-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "David Romaní",
            "email": "david@flux.cat"
        }
    ],
    "require": {
        "php": ">=8.2",
        "symfony/asset-mapper": "^6.4 || ^7.0 || ^8.0",
        "symfony/form": "^6.4 || ^7.0 || ^8.0",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/stimulus-bundle": "^2.20 || ^3.0",
        "symfony/translation": "^6.4 || ^7.0 || ^8.0",
        "symfony/twig-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/ux-icons": "^2.20 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.5",
        "symfony/phpunit-bridge": "^6.4 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "FlexibleUx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FlexibleUx\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
